# CogniVault Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Reown (WalletConnect) Project ID — get from https://dashboard.reown.com
VITE_REOWN_PROJECT_ID=e2b89dc563814ce818711b10fae02f75

# Pipeline API URL — the base URL where the AI agent serves state.json
# If set, the frontend fetches live pipeline data from {VITE_PIPELINE_API_URL}/state.json
# If unset, falls back to the bundled /state.json (static, frozen at build time)
# Example: VITE_PIPELINE_API_URL=https://api.cognivault.xyz
VITE_PIPELINE_API_URL=
