# CogniVault Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Reown (WalletConnect) Project ID — get from https://dashboard.reown.com
VITE_REOWN_PROJECT_ID=e2b89dc563814ce818711b10fae02f75

# Pipeline API URL — live telemetry only (state.json). Contract addresses always
# load from the bundled /deployments.json copied at build time.
# Example: VITE_PIPELINE_API_URL=https://cognivault-ai-agent.onrender.com
VITE_PIPELINE_API_URL=
