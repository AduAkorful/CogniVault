# ============================================================
# CogniVault Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Wallet
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
TEE_SIGNER=0x822B9030e8051cC296c5B76ad8B1Bcb9dbF8eB62

# 0G Network
RPC_URL=https://evmrpc-testnet.0g.ai
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# 0G DA Client
DA_CLIENT_GRPC=localhost:51001

# 0G Compute
COMPUTE_PROVIDER=0x0000000000000000000000000000000000000000

# Mock modes (set to false for production)
MOCK_STORAGE=true
MOCK_COMPUTE=true
MOCK_DA=true
MOCK_RELAYER=true

# Relayer
RELAYER_INTERVAL_MS=60000
RELAYER_MAX_CYCLES=0

# Deployed Contracts (populated after forge script deployment)
VAULT_ADDRESS=
LENDING_POOL_ADDRESS=
AMM_POOL_ADDRESS=
MOCK_USDC_ADDRESS=
PRICE_ORACLE_ADDRESS=
