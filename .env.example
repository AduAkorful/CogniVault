# ============================================================
# CogniVault Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Wallet (deployer + pool owner)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# TEE Signer (generates strategy signatures inside the TEE)
TEE_SIGNER=0x_YOUR_TEE_SIGNER_ADDRESS
TEE_PRIVATE_KEY=0x_YOUR_TEE_PRIVATE_KEY

# 0G Network
RPC_URL=https://evmrpc-testnet.0g.ai
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# 0G DA Client (gRPC endpoint for blob dispersal)
DA_CLIENT_GRPC=localhost:51001

# 0G Compute (leave empty to auto-discover providers)
COMPUTE_PROVIDER=

# Relayer
RELAYER_INTERVAL_MS=60000
RELAYER_MAX_CYCLES=0

# Market Simulator
MARKET_SIM_INTERVAL_MS=300000

# Deployed Contracts (read from deployments.json at runtime)
VAULT_ADDRESS=
LENDING_POOL_ADDRESS=
AMM_POOL_ADDRESS=
USDC_ADDRESS=
PRICE_ORACLE_ADDRESS=
DA_ENTRANCE_ADDRESS=0x857C0A28A8634614BB2C96039Cf4a20AFF709Aa9
